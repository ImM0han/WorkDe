generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  phone         String    @unique
  name          String
  email         String?
  avatarUrl     String?
  role          Role      @default(CLIENT)
  isVerified    Boolean   @default(false)
  aadhaarStatus KYCStatus @default(PENDING)
  pushToken     String?
  createdAt     DateTime  @default(now())
  
  // Auth fields
  passwordHash  String?
  loginMethod   LoginMethod @default(OTP)
  failedAttempts Int        @default(0)
  lockedUntil   DateTime?
  gender        String?

  partner       Partner?
  clientJobs    Job[]     @relation("ClientJobs")
  messages      Message[]
  disputes      Dispute[]
  notifications Notification[]
  savedAddresses SavedAddress[]
}

enum LoginMethod {
  OTP
  PASSWORD
  BOTH
}

model Partner {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  userId        String        @unique @db.ObjectId
  user          User          @relation(fields:[userId], references:[id])
  gender        String?
  skills        String[]
  certificates  Certificate[]
  walletBalance Float         @default(0)
  isOnline      Boolean       @default(false)
  lastLat       Float?
  lastLng       Float?
  rating        Float         @default(0)
  totalJobs     Int           @default(0)
  acceptedJobs  Job[]         @relation("PartnerJobs")
  bankAccounts  BankAccount[]
}

model Job {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  clientId         String    @db.ObjectId
  client           User      @relation("ClientJobs", fields:[clientId], references:[id])
  partnerId        String?   @db.ObjectId
  partner          Partner?  @relation("PartnerJobs", fields:[partnerId], references:[id])
  category         String
  description      String
  lat              Float
  lng              Float
  address          String
  rateType         RateType  @default(DAILY)
  rate             Float
  status           JobStatus @default(POSTED)
  scheduledDate    DateTime
  workerCount      Int       @default(1)
  femaleOnly       Boolean   @default(false)
  seasonLabel      String?
  materialsIncluded Boolean  @default(false)
  materialCost     Float?
  acceptedCount    Int       @default(0)
  partnerIds       String[]
  completionPhotos String[]
  completionNotes  String?
  createdAt        DateTime  @default(now())
  payment          Payment?
  feedback         Feedback?
  messages         Message[]
  disputes         Dispute[]
}

model Payment {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  jobId             String        @unique @db.ObjectId
  job               Job           @relation(fields:[jobId], references:[id])
  amount            Float
  platformFee       Float
  netAmount         Float
  status            PaymentStatus @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?
  method            String?
  createdAt         DateTime      @default(now())
}

model Feedback {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  jobId     String   @unique @db.ObjectId
  job       Job      @relation(fields:[jobId], references:[id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}

model Certificate {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  partnerId       String     @db.ObjectId
  partner         Partner    @relation(fields:[partnerId], references:[id])
  skill           String
  name            String
  issuingOrg      String
  issueDate       DateTime
  expiryDate      DateTime?
  fileUrl         String
  status          CertStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime   @default(now())
}

model BankAccount {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  partnerId     String   @db.ObjectId
  partner       Partner  @relation(fields:[partnerId], references:[id])
  accountNumber String
  ifsc          String
  holderName    String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model SavedAddress {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields:[userId], references:[id])
  label       String   // 'Home' | 'Work' | 'Other'
  customLabel String?  // used when label = 'Other'
  name        String   // contact name at this address
  phone       String   // contact phone at this address
  flat        String   // flat / house / building number
  street      String   // street / locality / area
  landmark    String?  // optional landmark
  city        String
  state       String
  pincode     String
  lat         Float
  lng         Float
  fullAddress String   // formatted single-line address
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  jobId     String   @db.ObjectId
  job       Job      @relation(fields:[jobId], references:[id])
  senderId  String   @db.ObjectId
  sender    User     @relation(fields:[senderId], references:[id])
  text      String?
  imageUrl  String?
  isRead    Boolean  @default(false)
  timestamp DateTime @default(now())
}

model Dispute {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  jobId        String        @db.ObjectId
  job          Job           @relation(fields:[jobId], references:[id])
  raisedById   String        @db.ObjectId
  raisedBy     User          @relation(fields:[raisedById], references:[id])
  type         DisputeType
  description  String
  evidence     String[]
  status       DisputeStatus @default(OPEN)
  ticketNumber String        @unique
  resolution   String?
  createdAt    DateTime      @default(now())
  resolvedAt   DateTime?
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields:[userId], references:[id])
  type      String
  title     String
  body      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum Role {
  PARTNER
  CLIENT
}

enum KYCStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum JobStatus {
  POSTED
  ACCEPTED
  IN_PROGRESS
  EXTENDED
  COMPLETED
  CANCELLED
}

enum RateType {
  HOURLY
  DAILY
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum CertStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DisputeType {
  PAYMENT_ISSUE
  CLIENT_NO_SHOW
  UNSAFE_CONDITIONS
  QUALITY_ISSUE
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}
